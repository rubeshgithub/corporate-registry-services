---
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-top">
      <!-- Brand column -->
      <div>
        <a href="/" class="logo">
          <div class="logo-mark">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2l1.5 4h3l-2.5 2 1 3.5L12 10l-3 1.5 1-3.5L7.5 6h3L12 2z M12 10v10 M9 16h6"/>
            </svg>
          </div>
          <div class="logo-text">
            <span class="logo-crs">CRS</span>
            <span class="logo-sub">Corporate Registry Services</span>
          </div>
        </a>
        <p class="footer-brand-desc">
          Canada's trusted corporate registry specialists. Federal and provincial
          incorporation, compliance, and minute book services — all in one place.
        </p>
        <address class="footer-address">
          Corporate Registry Services Inc.<br />
          Serving all provinces &amp; territories<br />
          Federally registered — Canada
        </address>
      </div>

      <!-- Services column -->
      <div>
        <div class="footer-col-title">Services</div>
        <ul class="footer-links-list">
          <li><a href="/profile-reports">Corporate Profile Reports</a></li>
          <li><a href="/good-standing">Certificates of Good Standing</a></li>
          <li><a href="/annual-return">Annual Returns</a></li>
          <li><a href="/minute-books">Corporate Minute Books</a></li>
          <li><a href="/incorporation">Incorporation</a></li>
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <div class="footer-col-title">Company</div>
        <ul class="footer-links-list">
          <li><a href="/about">About CRS</a></li>
          <li><a href="/articles">Knowledge Hub</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <!-- Jurisdictions column -->
      <div>
        <div class="footer-col-title">Jurisdictions</div>
        <ul class="footer-links-list">
          <li><a href="/incorporation">Federal (CBCA)</a></li>
          <li><a href="/incorporation">Ontario</a></li>
          <li><a href="/incorporation">British Columbia</a></li>
          <li><a href="/incorporation">Alberta</a></li>
          <li><a href="/incorporation">All Provinces</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        © {year} <span>Corporate Registry Services</span>. All rights reserved.
      </p>
      <nav class="footer-legal">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </div>
</footer>
