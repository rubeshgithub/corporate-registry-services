---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  entry: CollectionEntry<any>;
  sectionLabel: string;
  sectionHref: string;
}

const { entry, sectionLabel, sectionHref } = Astro.props;
const { Content } = await render(entry);

const MB_URL = 'https://app.corporateregistryservices.ca';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://corporateregistryservices.ca' },
    { '@type': 'ListItem', position: 2, name: sectionLabel, item: `https://corporateregistryservices.ca${sectionHref}` },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: `https://corporateregistryservices.ca${sectionHref}/${entry.id}` },
  ],
};

// Province lookup from slug
const PROVINCES: Record<string, string> = {
  'canada-federal':        'Canada — Federal (CBCA)',
  'ontario':               'Ontario',
  'british-columbia':      'British Columbia',
  'alberta':               'Alberta',
  'quebec':                'Québec',
  'manitoba':              'Manitoba',
  'saskatchewan':          'Saskatchewan',
  'nova-scotia':           'Nova Scotia',
  'new-brunswick':         'New Brunswick',
  'newfoundland':          'Newfoundland & Labrador',
  'prince-edward-island':  'Prince Edward Island',
  'northwest-territories': 'Northwest Territories',
  'nunavut':               'Nunavut',
  'yukon':                 'Yukon',
};
const province = (() => {
  const lower = entry.id.toLowerCase();
  for (const [key, name] of Object.entries(PROVINCES)) {
    if (lower.startsWith(key)) return name;
  }
  return '';
})();

const section = entry.data.section as string;
const isService = ['profile-reports','good-standing','annual-return','minute-books','incorporation'].includes(section);

// Processing strip — service-specific
const strip =
  section === 'minute-books'
    ? [['48 Hours','Delivery Time'],['Word + PDF','Editable Formats'],['Interac · Debit · Credit','Payment'],['CBCA Compliant','All Provinces']]
  : section === 'annual-return'
    ? [['On-Time Filing','Before Deadline'],['Email Receipt','Confirmation Provided'],['Interac · Debit · Credit','Payment'],['14 Jurisdictions','Federal & Provincial']]
  : section === 'incorporation'
    ? [['3–5 Business Days','Processing Time'],['Full Document Package','Everything Included'],['Interac · Debit · Credit','Payment'],['Lifetime Support','Good Standing']]
  : [['3 Hours','Processing Time'],['PDF','Electronic Delivery'],['Interac · Debit · Credit','Payment'],['Official','Government-Sourced']];
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<!-- â”€â”€â”€ Page Header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
<section class="page-detail-header">
  <div class="container">
    <nav class="detail-breadcrumb">
      <a href="/">Home</a>
      <span class="detail-breadcrumb-sep">/</span>
      <a href={sectionHref}>{sectionLabel}</a>
      <span class="detail-breadcrumb-sep">/</span>
      <span style="color:var(--cream)">{entry.data.title}</span>
    </nav>
    <h1 class="detail-title">{entry.data.title}</h1>
    <div class="processing-strip">
      {strip.map(([s, l]) => (
        <div class="processing-item"><strong>{s}</strong> — {l}</div>
      ))}
    </div>
  </div>
</section>

