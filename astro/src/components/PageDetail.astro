              </div>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="inc-name2">2nd Choice <span class="form-label-opt">(optional)</span></label>
                  <input id="inc-name2" class="form-input" type="text" name="proposed_name_2" placeholder="Alternative name" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="inc-name3">3rd Choice <span class="form-label-opt">(optional)</span></label>
                  <input id="inc-name3" class="form-input" type="text" name="proposed_name_3" placeholder="Alternative name" />
