---
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  intro: string;
  basePath: string;
  entries: CollectionEntry<any>[];
  serviceLabel?: string;
}

const { title, intro, basePath, entries, serviceLabel } = Astro.props;

const PROVINCE_DATA: Record<string, { abbr: string; province: string; capital: string; registry: string }> = {
  'canada-federal':        { abbr: 'FED', province: 'Canada — Federal',        capital: 'Ottawa, ON',         registry: 'Corporations Canada · CBCA' },
  'ontario':               { abbr: 'ON',  province: 'Ontario',                  capital: 'Toronto, ON',        registry: 'Ontario Business Registry' },
  'british-columbia':      { abbr: 'BC',  province: 'British Columbia',         capital: 'Victoria, BC',       registry: 'BC Registry Services' },
  'alberta':               { abbr: 'AB',  province: 'Alberta',                  capital: 'Edmonton, AB',       registry: 'Alberta Corporate Registry' },
  'quebec':                { abbr: 'QC',  province: 'Québec',                   capital: 'Québec City, QC',    registry: 'Registraire des entreprises' },
  'manitoba':              { abbr: 'MB',  province: 'Manitoba',                 capital: 'Winnipeg, MB',       registry: 'Companies Office Manitoba' },
  'saskatchewan':          { abbr: 'SK',  province: 'Saskatchewan',             capital: 'Regina, SK',         registry: 'ISC Saskatchewan' },
  'nova-scotia':           { abbr: 'NS',  province: 'Nova Scotia',              capital: 'Halifax, NS',        registry: 'Registry of Joint Stock Cos.' },
  'new-brunswick':         { abbr: 'NB',  province: 'New Brunswick',            capital: 'Fredericton, NB',    registry: 'Service New Brunswick' },
  'newfoundland':          { abbr: 'NL',  province: 'Newfoundland & Labrador',  capital: "St. John's, NL",     registry: 'Registry of Companies' },
  'prince-edward-island':  { abbr: 'PEI', province: 'Prince Edward Island',     capital: 'Charlottetown, PE',  registry: 'PEI Corporate Registry' },
  'northwest-territories': { abbr: 'NWT', province: 'Northwest Territories',    capital: 'Yellowknife, NT',    registry: 'NT Corporate Registry' },
  'nunavut':               { abbr: 'NU',  province: 'Nunavut',                  capital: 'Iqaluit, NU',        registry: 'Nunavut Dept. of Justice' },
  'yukon':                 { abbr: 'YK',  province: 'Yukon',                    capital: 'Whitehorse, YT',     registry: 'Corporate Affairs Yukon' },
};

function getProvince(slug: string) {
  const lower = slug.toLowerCase();
  for (const [key, data] of Object.entries(PROVINCE_DATA)) {
    if (lower.startsWith(key)) return data;
  }
  const first = slug.split('-')[0] ?? slug;
  return { abbr: first.slice(0, 3).toUpperCase(), province: first, capital: '', registry: '' };
}

const sorted = [...entries].sort((a, b) => {
  const aFed = a.data.slug.toLowerCase().includes('canada-federal');
  const bFed = b.data.slug.toLowerCase().includes('canada-federal');
  if (aFed && !bFed) return -1;
  if (!aFed && bFed) return 1;
  return a.data.title.localeCompare(b.data.title);
});

const section = basePath.replace(/^\//, '').replace(/-/g, ' ');
const isArticles = basePath === '/articles';

function getArticleProvince(id: string): string {
  const m = id.match(/-in-(.+)$/i);
  if (!m) return '';
  return m[1].replace(/-/g, ' ');
}

function truncateTitle(title: string, words = 8): string {
  const parts = title.split(' ');
  return parts.length > words ? parts.slice(0, words).join(' ') + '…' : title;
}
---

<!-- ─── Section Hero ──────────────────────────────────────── -->
<section class="section-hero">
  <div class="container">
    <div class="tag">{serviceLabel ?? section}</div>
    <h1 class="section-hero-title">{title}</h1>
    <p class="section-hero-intro">{intro}</p>
    <div class="trust-strip">
      {['Government-Direct Source', '3-Hour PDF Delivery', 'All 13 Jurisdictions', 'Interac · Debit · Credit'].map((t) => (
        <div class="trust-item"><span class="trust-dot"></span>{t}</div>
      ))}
    </div>
  </div>
</section>

<!-- ─── Province Grid ─────────────────────────────────────── -->
<section class="province-grid-section">
  <div class="container">

    {isArticles ? (
      <div class="article-grid">
        {sorted.map((entry) => {
          const province = getArticleProvince(entry.id);
          const shortTitle = truncateTitle(entry.data.title, 9);
          return (
            <a href={`${basePath}/${entry.id}`} class="article-card">
              {province && <div class="article-province-tag">{province}</div>}
              <div class="article-card-title">{shortTitle}</div>
              <div class="article-card-cta">
                Read Guide
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="province-grid">
        {sorted.map((entry) => {
          const prov = getProvince(entry.id);
          return (
            <a href={`${basePath}/${entry.id}`} class="province-card" data-abbr={prov.abbr}>
              <div class="province-abbr">{prov.abbr}</div>
              <div class="province-name">{prov.province}</div>
              {prov.capital && <div class="province-capital">{prov.capital}</div>}
              {prov.registry && <div class="province-registry">{prov.registry}</div>}
              <div class="province-cta">
                Order Now
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    )}

  </div>
</section>
