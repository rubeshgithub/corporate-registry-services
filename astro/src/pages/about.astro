---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const about = await getEntry('core', 'About-Us');
const { Content } = about ? await render(about) : { Content: null };
---

<BaseLayout title="About — Corporate Registry Services">
  <section class="container" style="padding: 3rem 0;">
    <span class="tag">About CRS</span>
    <h1>Your full-service partner for Canadian corporate compliance.</h1>
  </section>

  <section class="container prose" style="padding-bottom: 4rem;">
    {Content ? <Content /> : <p>About content not found.</p>}

    <h2>Why CRS</h2>
    <p>Corporate Registry Services helps domestic and foreign entrepreneurs, small businesses and professional firms manage the full lifecycle of a Canadian corporation — from incorporation, through annual filings, to dissolution.</p>
    <p>We work with the federal registry (Corporations Canada) and the corporate registries of all 10 provinces and 3 territories. One vendor, every jurisdiction.</p>

    <div style="margin-top: 2rem;">
      <a href="/contact" class="btn btn-accent">Contact our team</a>
    </div>
  </section>
</BaseLayout>
