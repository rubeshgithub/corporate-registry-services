---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageDetail from '~/components/PageDetail.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('annual-return');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'annual-return'> }
const { entry } = Astro.props;

const description = `File your ${entry.data.title} with CRS — Corporate Registry Services. We prepare and submit your annual return accurately and on time. Avoid administrative dissolution — stay compliant and in good standing.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: entry.data.title,
  description,
  provider: { '@type': 'ProfessionalService', name: 'Corporate Registry Services', url: 'https://corporateregistryservices.ca' },
  areaServed: 'Canada',
  serviceType: 'Annual Return Filing',
  offers: { '@type': 'Offer', priceCurrency: 'CAD', availability: 'https://schema.org/InStock' },
};
---
<BaseLayout
  title={`${entry.data.title} | CRS — Stay Compliant`}
  description={description}
  keywords={`${entry.data.title}, annual return filing Canada, corporation annual filing, corporate compliance Canada`}
  schema={schema}
>
  <PageDetail entry={entry} sectionLabel="Annual Return" sectionHref="/annual-return" />
</BaseLayout>
