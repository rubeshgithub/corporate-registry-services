---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionIndex from '~/components/SectionIndex.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('annual-return');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Corporate Annual Return Filing — Canada',
  description: 'Annual return filing for Canadian federal and provincial corporations. CRS prepares and files on your behalf to keep your corporation active and in good standing.',
  provider: { '@type': 'ProfessionalService', name: 'Corporate Registry Services', url: 'https://corporateregistryservices.ca' },
  areaServed: 'Canada',
  serviceType: 'Annual Return Filing',
};
---
<BaseLayout
  title="Corporate Annual Return Filing Canada — All Provinces | CRS"
  description="File your corporate annual return in Canada with CRS. We prepare and file annual returns for federal (CBCA) and all provincial corporations. Avoid dissolution — stay compliant. Available for all 13 Canadian jurisdictions from $49.99."
  keywords="annual return Canada, corporate annual return filing, Ontario annual return, BC annual return, Alberta annual return, CBCA annual return, annual corporate filing Canada, corporation compliance Canada"
  schema={schema}
>
  <SectionIndex
    title="Corporate Annual Returns"
    intro="Every active Canadian corporation must file an annual return to maintain good standing and avoid administrative dissolution. CRS prepares and files your annual return accurately and on time — for federal and all provincial corporations."
    basePath="/annual-return"
    entries={entries}
    serviceLabel="Annual Return Filing"
  />
</BaseLayout>
