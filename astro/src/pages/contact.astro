---
import BaseLayout from '~/layouts/BaseLayout.astro';

const contact = {
  email: 'hello@corporateregistryservices.ca',
  phone: '+1 (587) 587-5878',
  hours: '7 days a week, 24 hours a day',
};
---

<BaseLayout
  title="Contact Corporate Registry Services — CRS Canada"
  description="Contact CRS — Corporate Registry Services for incorporation, certificates of good standing, annual returns, minute books, or corporate profile reports. Our team responds within 1 business hour, 7 days a week."
  keywords="contact corporate registry services, CRS Canada contact, corporate registry help Canada"
>

<section class="section-hero" style="padding-bottom: 48px;">
  <div class="container">
    <div class="tag">Contact</div>
    <h1 class="section-hero-title">Talk to Our Team.</h1>
    <p class="section-hero-intro">
      Need a corporate document, a filing, or advice on which service you need?
      Our team responds within 1 business hour — every day, around the clock.
    </p>

    <!-- Contact info strip -->
    <div class="contact-info-strip">
      <a href={`mailto:${contact.email}`} class="contact-info-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m2 7 10 7 10-7"/>
        </svg>
        <span>{contact.email}</span>
      </a>
      <div class="contact-info-divider"></div>
      <a href={`tel:${contact.phone.replace(/\D/g, '')}`} class="contact-info-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.23h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
        </svg>
        <span>{contact.phone}</span>
      </a>
      <div class="contact-info-divider"></div>
      <div class="contact-info-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        <span>{contact.hours}</span>
      </div>
    </div>
  </div>
</section>

<!-- Single form section -->
<section style="padding: 0 0 100px;">
  <div class="container" style="max-width: 720px;">

    <div class="enquiry-section">
      <div class="mb-banner-eyebrow">Send a Message</div>
      <h2 class="enquiry-title">How Can We Help?</h2>
      <p class="enquiry-sub">Tell us what you need and we'll be in touch within 1 business hour.</p>

      <form
        name="contact"
        method="POST"
        action="/api/submit"
        class="enquiry-form"
      >
        <input type="hidden" name="form-name" value="contact" />

        <div class="form-row">
          <div class="form-field">
            <label class="form-label" for="c-name">Full Name</label>
            <input id="c-name" class="form-input" type="text" name="name" placeholder="Jane Smith" required />
          </div>
          <div class="form-field">
            <label class="form-label" for="c-email">Email Address</label>
            <input id="c-email" class="form-input" type="email" name="email" placeholder="jane@company.ca" required />
          </div>
        </div>

        <div class="form-field">
          <label class="form-label" for="c-company">Company Name</label>
          <input id="c-company" class="form-input" type="text" name="company" placeholder="Acme Corp. (optional)" />
        </div>

        <div class="form-field">
          <label class="form-label" for="c-service">Service You Need</label>
          <input id="c-service" class="form-input" type="text" name="service" placeholder="e.g. Certificate of Good Standing — Ontario" />
        </div>

        <div class="form-field">
          <label class="form-label" for="c-message">Message</label>
          <textarea id="c-message" class="form-textarea" name="message" placeholder="Tell us more about your needs..." required></textarea>
        </div>

        <button type="submit" class="btn-primary">Send Message →</button>
      </form>
    </div>

    <!-- Proudly Canadian note below form -->
    <div style="margin-top: 24px; display: flex; align-items: center; gap: 12px; padding: 18px 24px; background: rgba(30,77,56,0.12); border: 1px solid rgba(42,106,78,0.3);">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(75,180,120,0.8)" stroke-width="1.5" style="flex-shrink:0;">
        <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
      </svg>
      <p style="font-size: 13px; color: var(--cream-muted); margin: 0; line-height: 1.6;">
        <strong style="color: var(--cream);">Proudly Canadian.</strong>
        Serving federal and all provincial jurisdictions — no corporate matter is too large or too small.
      </p>
    </div>

  </div>
</section>

</BaseLayout>

<style>
  .contact-info-strip {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    margin-top: 36px;
    border: 1px solid var(--border);
    background: var(--card);
  }
  .contact-info-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 24px;
    color: var(--cream-muted);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
  a.contact-info-item:hover { color: var(--gold); }
  a.contact-info-item:hover svg { stroke: var(--gold); }
  .contact-info-item svg { stroke: var(--gold); flex-shrink: 0; }
  .contact-info-divider {
    width: 1px;
    height: 48px;
    background: var(--border);
  }
  @media (max-width: 700px) {
    .contact-info-strip { flex-direction: column; }
    .contact-info-divider { width: 100%; height: 1px; }
    .contact-info-item { width: 100%; }
  }
</style>
