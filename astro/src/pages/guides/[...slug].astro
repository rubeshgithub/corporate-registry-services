---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageDetail from '~/components/PageDetail.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('guides');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'guides'> }
const { entry } = Astro.props;

const description = `${entry.data.title} — Free guide from CRS Corporate Registry Services. Expert plain-language explanation for Canadian business owners and entrepreneurs.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description,
  author: { '@type': 'Organization', name: 'Corporate Registry Services', url: 'https://corporateregistryservices.ca' },
  publisher: { '@type': 'Organization', name: 'Corporate Registry Services', url: 'https://corporateregistryservices.ca' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://corporateregistryservices.ca/guides/${entry.id}` },
};
---
<BaseLayout
  title={`${entry.data.title} | CRS Guide`}
  description={description}
  keywords={`${entry.data.title}, canada corporate law, corporate compliance canada, CRS corporate registry`}
  schema={schema}
>
  <PageDetail entry={entry} sectionLabel="Guides" sectionHref="/guides" />
</BaseLayout>
