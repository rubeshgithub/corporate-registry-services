---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('guides');
const sorted = [...entries].sort((a, b) => a.data.title.localeCompare(b.data.title));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Canadian Corporate Compliance Guides — CRS',
  description: 'Free in-depth guides on Canadian corporate law, incorporation, certificates of good standing, annual returns, minute books, and NUANS name searches — written by corporate registry specialists.',
  url: 'https://corporateregistryservices.ca/guides',
  publisher: { '@type': 'ProfessionalService', name: 'Corporate Registry Services', url: 'https://corporateregistryservices.ca' },
};
---

<BaseLayout
  title="Canadian Corporate Compliance Guides | CRS — Free Expert Resources"
  description="Free in-depth guides on Canadian corporate law: federal vs provincial incorporation, certificates of good standing, annual return deadlines, minute books, NUANS searches, and more. Written by CRS specialists."
  keywords="corporate compliance guides canada, how to incorporate canada, certificate of good standing guide, annual return canada guide, minute book canada, nuans name search guide"
  schema={schema}
>

<section class="section-hero">
  <div class="container">
    <div class="tag">Guides</div>
    <h1 class="section-hero-title">Free Canadian Corporate Guides.</h1>
    <p class="section-hero-intro">
      Plain-language guides on Canadian corporate law, compliance, and registry services —
      written by the specialists at CRS to help business owners make informed decisions.
    </p>
    <div class="trust-strip">
      {['Federal & All Provinces', 'Written by CRS Specialists', 'Plain-Language Explanations', 'Free to Access'].map((t) => (
        <div class="trust-item"><span class="trust-dot"></span>{t}</div>
      ))}
    </div>
  </div>
</section>

<section class="province-grid-section">
  <div class="container">
    <div class="article-grid">
      {sorted.map((entry) => (
        <a href={`/guides/${entry.id}`} class="article-card">
          <div class="article-province-tag">Guide</div>
          <div class="article-card-title">{entry.data.title}</div>
          <div class="article-card-cta">
            Read Guide
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>
