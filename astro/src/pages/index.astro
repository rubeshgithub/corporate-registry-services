---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServiceWizard from '~/components/wizard/ServiceWizard.astro';
---

<BaseLayout title="docu10 — Built for Modern Corporate Compliance">

<!-- ─── Hero ──────────────────────────────────────────────── -->
<section id="hero" class="hero-compact">
  <div class="hero-grid-bg"></div>
  <div class="hero-center">
    <div class="tag hero-eyebrow">Canada's Corporate Registry Specialists</div>
    <h1 class="hero-headline">Built for Modern<br /><em>Corporate Compliance.</em></h1>
    <div class="hero-gold-line"></div>
    <p class="hero-body">
      Order corporate documents, file changes, and manage compliance across all 13 Canadian
      jurisdictions — in minutes, not days.
    </p>
  </div>
</section>

<!-- ─── Wizard ─────────────────────────────────────────────── -->
<section id="order" class="wizard-outer">
  <div class="container">
    <ServiceWizard />
  </div>
</section>

<!-- ─── Marquee ────────────────────────────────────────────── -->
<div class="marquee-section">
  <div class="marquee-track">
    {[
      'Federal Incorporation', 'Provincial Registration', 'MinuteBook Compliance',
      'Annual Returns', 'Corporate Resolutions', 'Partnership Agreements',
      'Employer Contracts', 'Director Agreements',
      'Federal Incorporation', 'Provincial Registration', 'MinuteBook Compliance',
      'Annual Returns', 'Corporate Resolutions', 'Partnership Agreements',
      'Employer Contracts', 'Director Agreements',
    ].map((label) => (
      <div class="marquee-item">
        <span class="marquee-dot"></span>{label}
      </div>
    ))}
  </div>
</div>

<!-- ─── Services ──────────────────────────────────────────── -->
<section id="services">
  <div class="container">
    <div class="section-header reveal">
      <div class="tag">What We Do</div>
      <h2 class="section-title">Corporate services,<br /><em>precisely delivered.</em></h2>
      <p class="section-body">
        Every service is backed by direct government-registry access, professional
        review, and same-day electronic delivery across all 13 Canadian jurisdictions.
      </p>
    </div>

    <div class="services-grid">
      {[
        {
          n: '01', href: '/profile-reports',
          name: 'Corporate Profile Reports',
          desc: 'Official, government-sourced corporate records delivered as PDF within hours. Used by lawyers, lenders, and due-diligence teams.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
        },
        {
          n: '02', href: '/good-standing',
          name: 'Certificates of Good Standing',
          desc: 'Formal proof a corporation is registered, active and compliant — required by banks, investors, and regulators.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
        },
        {
          n: '03', href: '/annual-return',
          name: 'Annual Returns',
          desc: 'Stay compliant — we prepare and file your corporate annual return on time, every time, in any Canadian jurisdiction.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
        },
        {
          n: '04', href: '/minute-books',
          name: 'Corporate Minute Books',
          desc: 'Digital minute book with every register, resolution and template you need — always audit-ready.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>`,
        },
        {
          n: '05', href: '/incorporation',
          name: 'Incorporation Service',
          desc: 'Federal or provincial incorporation with Articles, Minute Book, and lifetime good-standing support included.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
        },
        {
          n: '06', href: '/articles',
          name: 'Knowledge Hub',
          desc: 'Guides, how-tos, and compliance updates for Canadian corporate professionals and business owners.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
        },
      ].map((s) => (
        <a href={s.href} class="service-card" style="text-decoration:none">
          <div class="service-number">{s.n}</div>
          <div class="service-icon">
            <svg viewBox="0 0 24 24" set:html={s.icon} />
          </div>
          <div class="service-name">{s.name}</div>
          <p class="service-desc">{s.desc}</p>
          <span class="service-link">
            Learn more
            <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ─── Stats ─────────────────────────────────────────────── -->
<section id="stats">
  <div class="container">
    <div class="stats-grid">
      {[
        { number: '10', suffix: '+', label: 'Years of Service', desc: 'Serving Canadian businesses since 2014' },
        { number: '15', suffix: 'K+', label: 'Corporations Served', desc: 'Federal and provincial across all sectors' },
        { number: '13', suffix: '', label: 'Jurisdictions', desc: 'Federal + all 10 provinces + 3 territories' },
        { number: '98', suffix: '%', label: 'Client Satisfaction', desc: 'Verified by post-service surveys' },
      ].map((s) => (
        <div class="stat-item reveal">
          <div class="stat-number">{s.number}<span class="stat-suffix">{s.suffix}</span></div>
          <div class="stat-label">{s.label}</div>
          <p class="stat-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─── Why CRS ────────────────────────────────────────────── -->
<section id="why">
  <div class="container">
    <div class="why-layout">
      <div>
        <div class="section-header reveal">
          <div class="tag">Why docu10</div>
          <h2 class="section-title">Built for<br /><em>Canadian law.</em></h2>
        </div>
        <div class="why-pillar-list">
          {[
            {
              n: '01',
              title: 'Government-Direct Access',
              text: 'We pull documents straight from CBCA, ONBCA, BCBCA, and every other registry — no intermediaries, no delays.',
            },
            {
              n: '02',
              title: 'Pan-Canadian Coverage',
              text: 'One vendor for all 13 jurisdictions. Federal, Ontario, BC, Alberta — docu10 covers the whole country.',
            },
            {
              n: '03',
              title: 'Professional Review',
              text: 'Every filing is reviewed by a corporate professional before submission. Errors are caught before they become problems.',
            },
            {
              n: '04',
              title: 'Same-Day Delivery',
              text: 'Most reports and certificates arrive electronically within 3 hours. Urgent filings processed same business day.',
            },
          ].map((p) => (
            <div class="why-pillar reveal">
              <div class="pillar-num">{p.n}</div>
              <div class="pillar-content">
                <div class="pillar-title">{p.title}</div>
                <p class="pillar-text">{p.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="why-visual reveal">
        <div class="why-big-text">
          Trusted by lawyers,<br /><em>accountants,</em><br />and lenders across Canada.
        </div>
        <p style="color:var(--text-body);font-size:15px;line-height:1.8;max-width:380px">
          docu10 is the back-office partner for hundreds of law firms, accounting
          practices, and lending institutions across Canada.
        </p>
        <div class="jurisdiction-list">
          {[
            { name: 'Canada Business Corporations Act', type: 'federal' },
            { name: 'Ontario Business Corporations Act', type: 'provincial' },
            { name: 'Business Corporations Act (BC)', type: 'provincial' },
            { name: 'Business Corporations Act (AB)', type: 'provincial' },
            { name: 'All Remaining Provinces & Territories', type: 'provincial' },
          ].map((j) => (
            <div class="jurisdiction-item">
              <span class="jur-name">{j.name}</span>
              <span class={`jur-badge ${j.type}`}>{j.type}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── Process ───────────────────────────────────────────── -->
<section id="process">
  <div class="container">
    <div class="section-header reveal">
      <div class="tag">How It Works</div>
      <h2 class="section-title">Four steps to<br /><em>full compliance.</em></h2>
    </div>

    <div class="process-steps">
      {[
        { n: '1', title: 'Choose Your Service', desc: 'Select the filing or document you need from our complete service menu.' },
        { n: '2', title: 'Provide Details',     desc: 'Complete a short, guided form. We collect exactly what the registry requires — nothing more.' },
        { n: '3', title: 'Professional Review', desc: 'A docu10 specialist reviews your submission and prepares the filing to registry standards.' },
        { n: '4', title: 'Receive Documents',   desc: 'Official documents delivered electronically, usually within 3 hours.' },
      ].map((s) => (
        <div class="step reveal">
          <div class="step-circle"><span class="step-num">{s.n}</span></div>
          <div class="step-title">{s.title}</div>
          <p class="step-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─── Compliance Banner ─────────────────────────────────── -->
<section id="compliance">
  <div class="container">
    <div class="compliance-inner reveal">
      <div class="compliance-text">
        <h2 class="compliance-title">
          Stay compliant.<br /><em>Stay protected.</em>
        </h2>
        <p class="compliance-body">
          Annual returns, director changes, share issuances — missed filings carry
          real penalties. CRS monitors your compliance calendar so nothing slips through.
        </p>
      </div>
      <div class="compliance-actions">
        <a href="#cta-final" class="btn-primary">Get Started</a>
        <a href="/annual-return" class="btn-ghost">Annual Returns</a>
      </div>
    </div>
  </div>
</section>

<!-- ─── Testimonials ──────────────────────────────────────── -->
<section id="testimonials">
  <div class="container">
    <div class="section-header reveal">
      <div class="tag">Client Testimonials</div>
      <h2 class="section-title">Trusted by<br /><em>professionals.</em></h2>
    </div>

    <div class="testimonials-grid">
      {[
        {
          quote: 'CRS has become our go-to for corporate profile reports. Fast, accurate, and the team actually knows Canadian corporate law inside out.',
          name: 'Sarah M.', role: 'Corporate Lawyer, Bay Street Firm', initials: 'SM',
        },
        {
          quote: 'We\'ve been using CRS for annual returns across 40+ client corporations. The process is seamless and we\'ve never missed a deadline.',
          name: 'James T.', role: 'CPA, Toronto Accounting Practice', initials: 'JT',
        },
        {
          quote: 'The minute book service is exceptional. Everything is organized, legally compliant, and ready for due diligence at any time.',
          name: 'Linda K.', role: 'CFO, Growth-Stage Company', initials: 'LK',
        },
      ].map((t) => (
        <div class="testimonial-card reveal">
          <div class="stars">
            <div class="star"></div>
            <div class="star"></div>
            <div class="star"></div>
            <div class="star"></div>
            <div class="star"></div>
          </div>
          <p class="testimonial-quote">"{t.quote}"</p>
          <div class="testimonial-author">
            <div class="author-avatar">{t.initials}</div>
            <div>
              <div class="author-name">{t.name}</div>
              <div class="author-role">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─── MinuteBook Section ────────────────────────────────── -->
<section id="minutebook-section">
  <div class="container">
    <div class="mb-split">
      <div class="reveal">
        <div class="tag" style="margin-bottom: 20px;">Digital Platform by docu10</div>
        <h2 class="section-title" style="margin-bottom: 24px;">
          Your Minute Book,<br /><em>always compliant.</em>
        </h2>
        <p style="font-size: 17px; color: var(--text-body); line-height: 1.8; margin-bottom: 36px; max-width: 480px;">
          Every Canadian corporation is legally required to maintain a proper minute book.
          MinuteBook is CRS's digital platform — keep all corporate records organized,
          searchable, and always audit-ready. No paper, no courier, no missing documents.
        </p>

        <ul class="mb-features">
          {[
            'Digital share certificates & share ledger',
            'Director & officer resolutions',
            'Annual meeting minutes & records',
            'e-Signature integration for documents',
            'CBCA & all provincial acts compliant',
            'Secure Canadian cloud storage',
          ].map((f) => (
            <li class="mb-feature-item">
              <span class="mb-check">
                <svg width="10" height="8" viewBox="0 0 10 8" fill="none">
                  <polyline points="1 4 4 7 9 1" stroke="var(--gold)" stroke-width="1.5" />
                </svg>
              </span>
              {f}
            </li>
          ))}
        </ul>

        <div class="hero-actions">
          <a href="https://minutebook.ca/register" class="btn-primary">Register Free →</a>
          <a href="https://minutebook.ca/login" class="btn-ghost">Already a member?</a>
        </div>
      </div>

      <div class="reveal" style="position: relative;">
        <div class="mb-preview-card">
          <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em; color: var(--gold); text-transform: uppercase; margin-bottom: 24px;">
            MinuteBook — Corporate Dashboard
          </div>

          {[
            { label: 'Corporate Profile', value: 'Complete', color: '#4CAF86' },
            { label: 'Share Certificates', value: '3 Issued', color: 'var(--gold)' },
            { label: 'Director Resolutions', value: '12 Filed', color: 'var(--gold)' },
            { label: 'Annual Returns', value: 'Up to Date', color: '#4CAF86' },
            { label: 'e-Signatures', value: '5 Pending', color: 'var(--cream-muted)' },
            { label: 'Minute Book Status', value: 'CBCA Compliant', color: '#4CAF86' },
          ].map((row) => (
            <div class="mb-preview-row">
              <span class="mb-preview-label">{row.label}</span>
              <span class="mb-preview-value" style={`color: ${row.color};`}>{row.value}</span>
            </div>
          ))}

          <div style="margin-top: 24px; padding: 16px; background: rgba(30,77,56,0.2); border: 1px solid rgba(42,106,78,0.3);">
            <div style="font-size: 13px; color: var(--cream-muted); line-height: 1.6;">
              <strong style="color: var(--cream); display: block; margin-bottom: 4px;">✓ Audit-Ready at Any Time</strong>
              All records maintained to federal and provincial corporate law standards.
            </div>
          </div>
        </div>
        <div style="position: absolute; bottom: -12px; right: -12px; width: 100%; height: 100%; border: 1px solid var(--border); z-index: -1;"></div>
      </div>
    </div>
  </div>
</section>

<!-- ─── CTA Final ──────────────────────────────────────────── -->
<section id="cta-final">
  <div class="container">
    <div class="cta-final-inner">
      <div class="tag cta-final-eyebrow">Ready to Begin</div>
      <h2 class="cta-final-title">
        Your corporation,<br /><em>handled with care.</em>
      </h2>
      <p class="cta-final-body">
        Join thousands of Canadian businesses that trust docu10 for their corporate
        filings, compliance, and minute book management.
      </p>
      <div class="cta-final-actions">
        <a href="/incorporation" class="btn-primary">Start Your Corporation</a>
        <a href="/contact" class="btn-ghost">Book a Consultation</a>
      </div>
      <div class="cta-divider"></div>
    </div>
  </div>
</section>

</BaseLayout>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.12 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
