---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageDetail from '~/components/PageDetail.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('minute-books');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'minute-books'> }
const { entry } = Astro.props;

const description = `Order your ${entry.data.title} from CRS. Includes all statutory registers, share certificates, by-laws, and resolutions — delivered digitally in Word and PDF. Fully compliant with CBCA and provincial corporate law.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: entry.data.title,
  description,
  provider: { '@type': 'ProfessionalService', name: 'Corporate Registry Services', url: 'https://corporateregistryservices.ca' },
  areaServed: 'Canada',
  serviceType: 'Corporate Minute Book',
  offers: { '@type': 'Offer', priceCurrency: 'CAD', availability: 'https://schema.org/InStock' },
};
---
<BaseLayout
  title={`${entry.data.title} | CRS — Complete & Compliant`}
  description={description}
  keywords={`${entry.data.title}, corporate minute book Canada, corporate records, share register, director register, corporate by-laws`}
  schema={schema}
>
  <PageDetail entry={entry} sectionLabel="Minute Books" sectionHref="/minute-books" />
</BaseLayout>
