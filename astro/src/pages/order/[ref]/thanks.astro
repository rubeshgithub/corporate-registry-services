---
export const prerender = false;
import BaseLayout from '~/layouts/BaseLayout.astro';
const { ref } = Astro.params;
---

<BaseLayout
  title={`Order Confirmed ${ref} — docu10`}
  description="Your order has been received. Our team will confirm within 1 business hour."
>

<section style="min-height: 70vh; display: flex; align-items: center;">
  <div class="container" style="text-align: center; max-width: 680px; margin: 0 auto; padding: 80px 24px;">

    <div style="margin-bottom: 32px; display: flex; justify-content: center;">
      <div style="width: 72px; height: 72px; border: 1.5px solid var(--gold); display: grid; place-items: center;">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </div>
    </div>

    <div class="tag" style="justify-content: center; margin-bottom: 20px;">Request Received</div>
    <h1 style="font-family: var(--font-display); font-size: clamp(32px,5vw,48px); font-weight: 700; color: var(--cream); margin-bottom: 16px; line-height: 1.15;">
      You're all set.
    </h1>

    <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; color: var(--gold); text-transform: uppercase; margin-bottom: 28px;">
      Reference: {ref}
    </div>

    <p style="font-size: 17px; color: var(--text-body); line-height: 1.8; margin-bottom: 40px; max-width: 520px; margin-left: auto; margin-right: auto;">
      We've received your order and sent a confirmation to your email. Our team will follow up within
      <strong style="color: var(--cream);">1 business hour</strong> to confirm details and get started.
    </p>

    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 60px;">
      <a href="/" class="btn-primary">Back to Home →</a>
      <a href="/contact" class="btn-ghost">Contact Us</a>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border);">
      <div style="padding: 28px 20px; background: var(--card); text-align: center;">
        <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px;">Step 1</div>
        <div style="font-size: 14px; color: var(--cream-muted); line-height: 1.6;">Confirmation email sent to you within 1 hour</div>
      </div>
      <div style="padding: 28px 20px; background: var(--card); text-align: center;">
        <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px;">Step 2</div>
        <div style="font-size: 14px; color: var(--cream-muted); line-height: 1.6;">Our team processes your order professionally</div>
      </div>
      <div style="padding: 28px 20px; background: var(--card); text-align: center;">
        <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px;">Step 3</div>
        <div style="font-size: 14px; color: var(--cream-muted); line-height: 1.6;">Documents delivered to your inbox on time</div>
      </div>
    </div>

  </div>
</section>

</BaseLayout>
