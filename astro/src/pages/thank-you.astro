---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Order Received — CRS Canada"
  description="Your order has been received. Our team will confirm receipt within 1 business hour and begin processing your corporate document."
>

<section class="section-hero" style="min-height: 70vh; display: flex; align-items: center;">
  <div class="container" style="text-align: center; max-width: 680px; margin: 0 auto;">

    <div style="margin-bottom: 32px; display: flex; justify-content: center;">
      <div style="width: 72px; height: 72px; border: 1.5px solid var(--gold); display: grid; place-items: center;">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </div>
    </div>

    <div class="tag" style="justify-content: center; margin-bottom: 20px;">Order Received</div>
    <h1 class="section-hero-title" style="margin-bottom: 20px;">We've Got Your Order.</h1>
    <p style="font-size: 17px; color: var(--text-body); line-height: 1.8; margin-bottom: 40px;">
      Our team will confirm receipt within <strong style="color: var(--cream);">1 business hour</strong>
      and follow up if we need any additional details. You'll receive your document by email as soon as it's ready.
    </p>

    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 60px;">
      <a href="/" class="btn-primary">Back to Home →</a>
      <a href="/contact" class="btn-ghost">Contact Us</a>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border);">
      <div style="padding: 28px 20px; background: var(--card); text-align: center;">
        <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px;">Step 1</div>
        <div style="font-size: 14px; color: var(--cream-muted); line-height: 1.6;">Email confirmation sent to you within 1 hour</div>
      </div>
      <div style="padding: 28px 20px; background: var(--card); text-align: center;">
        <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px;">Step 2</div>
        <div style="font-size: 14px; color: var(--cream-muted); line-height: 1.6;">Our team begins processing your document</div>
      </div>
      <div style="padding: 28px 20px; background: var(--card); text-align: center;">
        <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px;">Step 3</div>
        <div style="font-size: 14px; color: var(--cream-muted); line-height: 1.6;">PDF delivered to your inbox on time</div>
      </div>
    </div>

  </div>
</section>

</BaseLayout>
